# Nach .env kopieren und mit echten Werten befüllen. Niemals eine echte .env-Datei committen.
# Siehe README.md, wie diese Werte mit dem bestehenden deployments/postgres/- und deployments/keycloak/-Setup zusammenhängen.

APP_ENV=development
SERVER_HOST=localhost
SERVER_PORT=8080

# Entspricht dem veröffentlichten Port in deployments/postgres/compose.yml (5432).
DB_HOST=localhost
DB_PORT=5432
# Diese DB/diesen User genauso anlegen wie im Beispiel unter
# deployments/postgres/init/kunde/sql (create-db.sql / create-schema.sql), oder direkt
# per psql, z.B.:
#   docker exec -e PGPASSWORD=p postgres psql --dbname=postgres --username=postgres \
#     -c "CREATE USER app PASSWORD 'app';" -c "CREATE DATABASE app;" \
#     -c "GRANT ALL ON DATABASE app TO app;"
DB_NAME=app
DB_USER=app
# Das echte lokale Dev-Passwort steht in deployments/postgres/password.txt — keine
# Secrets in diese Datei kopieren, auch keine Beispiel-/Dummy-Werte.
DB_PASSWORD=changeme
# Das ursprüngliche deployments/postgres/compose.yml (dhi.io/postgres-Image) läuft mit
# "ssl=on", was DB_SSLMODE=require erfordert. Das aktuelle lokale
# Ersatz-Image (postgres:17-alpine, siehe Kommentar in deployments/postgres/compose.yml)
# läuft ohne TLS, weil dessen Standard-Datenverzeichnis nicht zum
# bestehenden TLS-Zertifikatspfad passt, daher braucht die lokale
# Entwicklung aktuell stattdessen DB_SSLMODE=disable.
DB_SSLMODE=disable

# deployments/keycloak/compose.yml veröffentlicht Keycloak auf den Host-Ports 8880 (HTTP)
# und 8843 (HTTPS), siehe deployments/keycloak/compose.yml. Der Realm/Client unten
# existieren noch nicht: die vorherige Abgabe hat nur einen Realm
# "javascript" mit einem Client "javascript-client" angelegt (siehe
# deployments/keycloak/ReadMe.md). Für diese Go-API einen neuen Realm (z.B. "workshop")
# und einen confidential/public Client (z.B. "go-rest-api") nach denselben
# Schritten anlegen, dann prüfen:
# https://localhost:8843/realms/workshop/.well-known/openid-configuration
KEYCLOAK_ISSUER_URL=http://localhost:8880/realms/workshop
KEYCLOAK_CLIENT_ID=go-rest-api
KEYCLOAK_REQUIRED_ROLE=
